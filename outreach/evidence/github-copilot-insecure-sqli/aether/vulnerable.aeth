// GitHub Copilot - insecure code generation (SQL injection, CWE-89).
// Peer-reviewed: Pearce et al., "Asleep at the Keyboard? Assessing the
// Security of GitHub Copilot's Code Contributions" (IEEE S&P 2022,
// arXiv:2108.09293) - ~40% of Copilot completions in security-relevant
// scenarios were vulnerable, SQL injection among the leading classes.
//
// This is the faithful shape of a Copilot-style login handler that
// concatenates the request parameter straight into the query. Aether, as
// the target language the agent emits, refuses it: E0713.
//
// Run:  aether check vulnerable.aeth   -> E0713

module Login
  requires capability db
  exports findUser
end

function findUser(username: String) returns String
  effects db.query
do
  // The exact completion the study flagged: user input concatenated in.
  return sqlQuery("SELECT * FROM users WHERE name = '" + username + "'")
end

function main() returns Unit
  effects db.query
do
  let _r: String = findUser("admin' OR '1'='1")
end
