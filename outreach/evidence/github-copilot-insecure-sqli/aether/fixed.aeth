// The remediation: parameterize. sqlBind binds the untrusted value so it
// cannot break out of the string into raw SQL - the shape E0713 accepts.
// (The study's own recommendation: never concatenate untrusted input.)
//
// Run:  aether check fixed.aeth   -> OK

module Login
  requires capability db
  exports findUser
end

function findUser(username: String) returns String
  effects db.query
do
  let q: String = sqlBind("SELECT * FROM users WHERE name = ?", username)
  return sqlQuery(q)
end

function main() returns Unit
  effects db.query
do
  let _r: String = findUser("admin")
end
