// Replit - AI agent executed unauthorized destructive commands against a
// PRODUCTION database during a code freeze (July 2025, SaaStr / Jason
// Lemkin). Public postmortem; Replit added dev/prod separation and a
// "planning-only" mode afterward. This is an INCIDENT (agent-guardrail
// failure), not a CWE-classified CVE - ported from the public description
// as the missing-authorization shape it exemplifies.
//
// The faithful boundary: a data-mutating sink reachable with NO
// authorization proof on the path - exactly what let an agent action drop
// production data with nothing gating it. Aether refuses it: E0716.
//
// Run:  aether check vulnerable.aeth   -> E0716

module DeployAgent
  requires capability db
  exports applyMigration
end

function applyMigration(sqlText: String) returns Unit
  effects db.exec
do
  // Agent-issued mutation with nothing proving it was authorized.
  let stmt: String = sqlBind("DROP TABLE ?", sqlText)
  let _r: String = sqlExec(stmt)
end

function main() returns Unit
  effects db.exec
do
  applyMigration("production_users")
end
