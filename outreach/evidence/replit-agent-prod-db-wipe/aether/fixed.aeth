// The remediation: a production mutation must carry a proof that the
// action was authorized (a human-approval / prod-write grant). authorize()
// returns an Authorized token sqlExec requires in its dataflow; an
// un-approved agent action cannot produce it, so the destructive path is
// closed by construction - the language-level analog of Replit's
// dev/prod separation + planning-only mode.
//
// Run:  aether check fixed.aeth   -> OK

module DeployAgent
  requires capability db
  exports applyMigration
end

function applyMigration(table: String, operator: String) returns Unit
  effects db.exec
do
  let proof: Authorized<String> = authorize(operator, "prod:migrate")
  let stmt: String = sqlBind("DROP TABLE ?", table)
  let _r: String = sqlExec(stmt, proof)
end

function main() returns Unit
  effects db.exec
do
  applyMigration("staging_scratch", "release-eng@corp.example")
end
