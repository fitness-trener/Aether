type Email = String where contains?(self, "@")

function domainOf(addr: Email) returns String
  effects pure
do
  var i: Int = length(addr) - 1
  while i >= 0 do
    if slice(addr, i, i + 1) == "@" then
      return slice(addr, i + 1, length(addr))
    end
    i = i - 1
  end
  return ""
end

function main() returns Unit
  effects log
do
  print(domainOf("not-an-email"))
end
