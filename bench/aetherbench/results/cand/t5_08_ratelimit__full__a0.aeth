function allow(count: Int, limit: Int) returns Bool
  requires limit >= 0
  effects pure
do
  return count < limit
end

function main() returns Unit
  effects log
do
  var count: Int = 0
  let limit: Int = 3
  var i: Int = 0
  while i < 5 do
    if allow(count, limit) then
      print("allow")
    else
      print("deny")
    end
    count = count + 1
    i = i + 1
  end
end
