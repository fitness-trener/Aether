function sumTo(n: Int) returns Int
  requires n >= 0
  ensures result >= 0
  effects pure
do
  var total: Int = 0
  var i: Int = 1
  while i <= n do
    total = total + i
    i = i + 1
  end
  return total
end

function main() returns Unit
  effects log
do
  print(intToString(sumTo(10)))
  print(intToString(sumTo(0)))
end
