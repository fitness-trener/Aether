function fib(n: Int) returns Int
  requires n >= 0
  ensures result >= 0
  effects pure
do
  var a: Int = 0
  var b: Int = 1
  var i: Int = 0
  while i < n do
    var next: Int = a + b
    a = b
    b = next
    i = i + 1
  end
  return a
end

function main() returns Unit
  effects log
do
  print(intToString(fib(10)))
  print(intToString(fib(1)))
end
