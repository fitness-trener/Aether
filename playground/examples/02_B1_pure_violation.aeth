// Example 02 — B.1 effect locality violation.
// `validate` is declared `pure`, but logs a debug line. Aether
// refuses with [E0801]; Python would silently leak the data.
// Click "check" to see the diagnostic.

function validate(payload: String) returns Bool
  effects pure
do
  print("DEBUG validating " + payload)
  return length(payload) > 0
end

function main() returns Unit
  effects log
do
  if validate("hello") then
    print("ok")
  end
end
